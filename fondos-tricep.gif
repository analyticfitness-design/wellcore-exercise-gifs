			/** COOKIES **/
.cli_messagebar_head {
	color: #D500F9 !important;
}

.cookielawinfo-row-cat-table tbody {
	color: white !important;
}

.cli-bar-message {
    text-align: justify !important; 
}

.wt-cli-manage-consent-link {
  color: #FF5722 !important;   
  cursor: pointer !important; 
}

.wt-cli-ckyes-brand-logo {
	display: none !important;
}

/** FILTRO ***/
.search-filter-container {
    display: flex;
    align-items: center;
    margin: 10px;  
}

#filter-button {
    margin-left: 10px;
    padding: 10px !important;
    width: 300px;
}

.filter-window {
    width: 50%;
    display: none;
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background-color: black;
	color: white;
    padding: 20px;
    border: 1px solid black;
    box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
    z-index: 1000;
	 max-height: 100vh; /* Limita la altura máxima al 80% de la vista */
    overflow-y: auto; /* Habilita el scroll vertical si es necesario */
}

.filter-buttons {
    margin: 10px;
    display: flex;
    justify-content: space-between;
}

.filter-buttons button {
    padding: 10px;
    min-width: 100px;
    cursor: pointer;
}

@media (max-width: 768px) {
  .filter-window {
    width: 100%;
    max-height: 100vh; /* Asegura que el scroll funcione en pantallas pequeñas también */
  }
}

/****************
 * LISTADOS
 * **************/
#count-container {
	display: flex;    
    margin: 10px;  
	justify-content: space-between;
}

.view-toggle-container button {
	width: 80px !important;
	margin: 0px !important;
	padding: 0px !important;
}

.view-toggle-container span {
	font-size: 2em;
}

/* Vista de Cuadrícula */
.item-grid {
    margin: 2%;
    gap: 8px;
    display: flex;
    flex-wrap: wrap;
    justify-content: space-around;
}

.item-grid .view-item {
    background: #4A148C;
    border-radius: 10px;
    position: relative;
    width: calc(12.5% - 10px);
    box-shadow: 2px 2px 5px 0px rgba(191, 54, 12, 0.8) !important;
    text-align: center !important;
    color: #fff !important;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: all 0.3s ease;
}

.view-item a {
    color: #fff !important;
    text-decoration: none;
}

.item-image img {
    width: 100%;
    aspect-ratio: 1 / 1; /* Proporción 1:1 */
    /*object-fit: cover; */
}

.item-type {
    padding: 0px 5px 0 5px;
	font-size: 12px;    
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.item-name {
    font-size: 14px;
    font-weight: bold;
    padding: 0px 5px !important;
}

.info-oculta {
    font-size: 12px !important;
    display: none;
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    padding: 5px;
    border-radius: 10px;
    overflow: auto;
    transition: opacity 0.3s;
    background: rgba(74, 20, 140, 0.95) !important;
}

.view-item:hover .info-oculta {
    display: block !important;
    opacity: 1;
}

/* Vista de Listado */
.list-view .view-item {
    width: calc(33% - 10px);
    margin-bottom: 10px;       
    transition: all 0.3s ease;
}

.list-view .item-image {
	width: 49%;
}

.list-view .info-oculta {
	width: 50%;
	display: block !important;
    position: absolute;
    left: auto;
    font-size: 14px !important;
}

.list-view .item-type {
	display: none !important;
}


/* Ajustes responsivos para cuadrícula */
@media (max-width: 1024px) {
    .item-grid .view-item {
        width: calc(16.66% - 10px);
    }
	.item-grid.list-view .exercise-item {
    width: 49% !important;
}
}

@media (max-width: 768px) {
    .item-grid .view-item {
        width: calc(25% - 10px);
    }
    .item-grid .view-item div {
        font-size: 10px;
    }	
		.info-oculta {
    font-size: 8px !important;
}
	.list-view .item-name {
    font-size: 14px !important;
}
	.item-grid.list-view .view-item {
    width: 100% !important;
}
}
/****************
 * FIN LISTADOS
 * **************/





















/*** FICHAS COMUN ***/
.titulo_items_relacionados {
	text-align: center !important;	
}
.elementor-widget-theme-post-content {
	color: white !important;
}

/*** FICHA ALIMENTOS ***/
#input_gramos {
	color: black;
	text-align: center !important;	
}
.nutritional-info td:first-child {
    width: 40%;
}
#slider_alimentos {
	width: 100%;	
    box-shadow: none;	 
    padding: 0; 
}


/*** alimentos relacionados ***/
.tabla_alimentos_relacionados {
    font-size: 12px;
    text-align: center;
    display: flex;
    overflow-x: auto;
    padding-bottom: 80px;
}

.alimento_relacionado {
    margin: 8px;
}

.alimento_relacionado img {
    border-radius: 50px;
    min-height: 100px;
    border: solid 2px #4A148C;
    box-shadow: 2px 2px 5px 0px rgba(156, 39, 176, 0.6);
}

.alimento_relacionado a {
    font-size: 14px;
    display: block;
    width: 100px;
    max-height: 80px;
}

.alimento_relacionado a:hover {
    font-weight: bold;
}

@media screen and (max-width:767px) {
	.titulo_items_relacionados {
		font-size: 22px;
	}
	.alimento_relacionado img {
		min-height: 50px;
	}
	.alimento_relacionado a { 
		width: 50px;
		max-height:15px;
		font-size: 8px;
	}
	#btn_aplicar_racion {
		font-size: 12px !important;
	}
}



/****** FICHA EJERCICIO ******/
/*** ejercicios relacionados ***/
.tabla_ejercicios_relacionados {
  font-size: 12px;
	text-align: center;
	display: flex;
    overflow-x: auto;
    padding-bottom: 100px;
}

.tabla_ejercicios_relacionados a {
  font-size: 12px;
	text-align: center;
}
.ejercicio_relacionado {
  margin: 8px; 
  float: left;   
}
.ejercicio_relacionado img {
  border-radius: 5px;
  min-height:100px;
	height: 100px;
  border: solid 2px #4A148C; 
	box-shadow: 2px 2px 5px 0px rgba(156,39,176 , 0.6); 
}
.ejercicio_relacionado a {    
  display:block;
  text-align: center;
  width: 100px;
  max-height:70px;
}
.ejercicio_relacionado a:hover {
  font-weight: bold;
}

@media screen and (max-width:767px) {
	.ejercicio_relacionado img {
		min-height: 50px;
		height: 50px;
	}
	.ejercicio_relacionado a { 
		width: 50px;
		max-height: 1px;
		font-size: 8px;
	}
}








.training-posts {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
}

.training-post-card {
    background-color: #f9f9f9;
    border: 1px solid #ddd;
    padding: 15px;
    border-radius: 10px;
    width: 100%;
    max-width: auto;
}

.training-header {
    display: flex;
    align-items: center;
    
}

.user-info {
    text-align: center;
}

.training-header .user-avatar {
    border-radius: 50% !important;
    width: 50px;
    height: 50px;
    margin-right: 10px;
}

.training-days-scroll {
    display: flex;
    overflow-x: auto;
    gap: 10px;
    margin-top: 10px;
}

.training-day-box {
    min-width: 150px;	
	  border: 1px solid;
    padding: 10px;
    border-radius: 10px;
    text-align: center;
}



















































/*scroll chat*/
