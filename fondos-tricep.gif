<script>
window.addEventListener('scroll', function() {
    var languageWrapper = document.getElementById('gt_float_wrapper');
    if (window.scrollY === 0) {
        languageWrapper.style.display = 'block'; // Mostrar al principio
    } else {
        languageWrapper.style.display = 'none';  // Ocultar al hacer scroll
    }
});
</script>

